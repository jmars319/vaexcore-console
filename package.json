{
  "name": "vaexcore-console",
  "version": "0.1.2",
  "author": "Jason Marshall",
  "private": true,
  "description": "vaexcore console is a quiet Twitch operations bot for commands, moderation, giveaways, and stream control without the usual clutter.",
  "type": "module",
  "main": "desktop/shared/electron/main.cjs",
  "scripts": {
    "dev": "tsx desktop/shared/src/index.ts",
    "dev:local": "tsx desktop/shared/src/dev/local.ts",
    "setup": "tsx desktop/shared/src/setup/server.ts",
    "dev:app-config": "node scripts/run-live-from-app-config.mjs",
    "app:dev": "npm run build && node scripts/run-electron-app.mjs .",
    "app:build": "npm run app:build:mac",
    "app:build:mac": "npm run build && node scripts/run-electron-builder.mjs --mac dir && node desktop/macOS/scripts/install-electron-better-sqlite3.mjs && node scripts/smoke-packaged-asar.mjs --platform mac",
    "app:build:windows": "npm run build && node scripts/run-electron-builder.mjs --win dir && node desktop/windows/scripts/install-electron-better-sqlite3.mjs && node scripts/smoke-packaged-asar.mjs --platform win",
    "app:dist:windows": "npm run build && node scripts/run-electron-builder.mjs --win nsis portable && node desktop/windows/scripts/install-electron-better-sqlite3.mjs && node scripts/smoke-packaged-asar.mjs --platform win",
    "app:dist": "npm run app:dist:mac",
    "app:dist:mac": "npm run build && node scripts/run-electron-builder.mjs --mac dir && node desktop/macOS/scripts/install-electron-better-sqlite3.mjs && node desktop/macOS/scripts/build-mac-dmg-from-app.mjs",
    "app:zip": "npm run app:build && node desktop/macOS/scripts/package-unsigned-mac.mjs",
    "check:env": "tsx desktop/shared/src/cli/checkEnv.ts",
    "build": "tsc && esbuild desktop/shared/src/setup/server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-bundle/setup-server.js && esbuild desktop/shared/src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-bundle/live-bot.js && node scripts/copy-setup-ui.mjs",
    "release:guard": "node scripts/verify-release-git-state.mjs",
    "release:handoff": "node scripts/write-release-handoff.mjs",
    "release:check": "node scripts/verify-release-metadata.mjs",
    "release:unsigned": "node desktop/macOS/scripts/release-unsigned.mjs",
    "smoke:tester-guide": "node scripts/smoke-tester-guide.mjs",
    "smoke:tester-artifact": "node desktop/macOS/scripts/smoke-tester-artifact.mjs",
    "smoke:tester-update": "node desktop/macOS/scripts/smoke-tester-artifact.mjs --preserve-data",
    "smoke:queue": "tsx scripts/smoke-message-queue.mjs",
    "smoke:setup": "npm run build && node scripts/smoke-setup-ui.mjs",
    "smoke:commands": "npm run build && node scripts/smoke-custom-commands.mjs",
    "smoke:guardrails": "npm run build && tsx scripts/smoke-operational-guardrails.mjs",
    "smoke:timers": "npm run build && tsx scripts/smoke-timers.mjs",
    "smoke:moderation": "npm run build && tsx scripts/smoke-moderation.mjs",
    "smoke:replacement": "npm run build && node scripts/smoke-bot-replacement.mjs",
    "smoke:giveaway": "npm run build && node scripts/smoke-giveaway-readiness.mjs",
    "smoke:giveaway-live": "npm run build && node scripts/smoke-giveaway-live.mjs",
    "smoke:token-refresh": "npm run build && node scripts/smoke-token-refresh.mjs",
    "smoke:diagnostics": "npm run build && node scripts/smoke-diagnostics.mjs",
    "smoke:clean-install": "npm run build && node scripts/smoke-clean-install.mjs",
    "smoke:desktop-platforms": "node scripts/verify-desktop-platform-config.mjs",
    "smoke:studio": "tsx scripts/smoke-studio-integration.ts && tsx scripts/smoke-studio-marker-metadata.ts && tsx scripts/smoke-suite-validation.ts",
    "smoke:visual": "node scripts/visual-smoke.mjs",
    "smoke:unsigned-release": "npm run app:zip && node desktop/macOS/scripts/smoke-unsigned-release.mjs",
    "smoke:cli-env": "npm run build && tsx scripts/smoke-cli-env-bootstrap.mjs",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.vaexil.vaexcore.console",
    "productName": "vaexcore console",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "npmRebuild": false,
    "afterPack": "desktop/windows/scripts/electron-builder-after-pack.cjs",
    "afterSign": "desktop/macOS/scripts/electron-builder-after-sign.cjs",
    "files": [
      "dist/**/*",
      "dist-bundle/**/*",
      "desktop/shared/assets/**/*",
      "desktop/shared/electron/**/*",
      "desktop/macOS/assets/icon.icns",
      "desktop/windows/assets/icon.ico",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "desktop/macOS/assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dir",
        "dmg"
      ]
    },
    "win": {
      "icon": "desktop/windows/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "vaexcore-console-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "vaexcore console"
    },
    "dmg": {
      "artifactName": "vaexcore-console-${version}-${arch}.${ext}"
    }
  }
}
